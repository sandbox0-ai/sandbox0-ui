{
  "name": "@sandbox0/ui",
  "version": "0.0.1",
  "description": "Shared Sandbox0 pixel UI primitives and Tailwind theme preset.",
  "type": "module",
  "sideEffects": [
    "./dist/globals.css",
    "./src/globals.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./globals.css": "./dist/globals.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && cp src/globals.css dist/globals.css",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
